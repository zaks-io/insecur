{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/tenant-store": {
      "entry": [
        "scripts/**/*.mjs",
        "scripts/**/*.ts",
        "src/db/schema/**/*.ts",
        "vitest*.config.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"],
      "ignoreBinaries": ["tsx"],
      "ignoreDependencies": ["tsx"]
    },
    "packages/worker-kit": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/api": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/runtime": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    ".": {
      "entry": [
        "scripts/**/*.mjs",
        "examples/**/*.mjs",
        "*.config.ts",
        "stryker.config.mjs"
      ],
      "project": ["scripts/**/*.mjs"],
      "ignoreBinaries": ["wrangler"]
    }
  },
  "rules": {
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "duplicates": "off"
  }
}
