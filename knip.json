{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/tenant-store": {
      "entry": [
        "scripts/**/*.mjs",
        "scripts/**/*.ts",
        "src/db/schema/**/*.ts",
        "vitest*.config.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/secret-store": {
      "entry": ["vitest*.config.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/machine-auth": {
      "entry": ["vitest*.config.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/worker-kit": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/api": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/runtime": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    ".": {
      "entry": ["scripts/**/*.mjs", "examples/**/*.mjs", "*.config.ts", "*.config.mjs"],
      "project": ["scripts/**/*.mjs"],
      "ignoreDependencies": ["dependency-cruiser", "wrangler"]
    }
  },
  "ignoreBinaries": ["actionlint"]
}
