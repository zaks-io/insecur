{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/tenant-store": {
      "entry": [
        "scripts/**/*.mjs",
        "scripts/**/*.ts",
        "src/db/schema/**/*.ts",
        "vitest*.config.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "test/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/secret-store": {
      "entry": ["vitest*.config.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/backup-restore": {
      "entry": ["vitest*.config.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/machine-auth": {
      "entry": ["vitest*.config.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/local-store": {
      "entry": ["src/**/*.test.ts", "src/os-keychain.integration-child.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/high-assurance": {
      "entry": ["vitest*.config.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/worker-kit": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/api": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/site": {
      "entry": ["src/router.tsx", "src/start.ts", "src/routes/**/*.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "apps/runtime": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    "apps/web": {
      "entry": ["vitest*.config.ts", "src/**/*.test.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts"],
      "ignoreDependencies": ["cloudflare", "miniflare"]
    },
    ".": {
      "entry": [
        "config/**/*.ts",
        "scripts/**/*.mjs",
        "examples/**/*.mjs",
        "*.config.ts",
        "*.config.mjs"
      ],
      "project": ["config/**/*.ts", "scripts/**/*.mjs"],
      "ignoreDependencies": ["@sentry/cli", "dependency-cruiser"]
    }
  },
  "ignoreBinaries": ["actionlint"]
}
