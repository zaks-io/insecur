{
  "name": "@insecur/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "topo": "node -e \"\"",
    "build": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run --outdir dist --env=\"\"",
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs wrangler dev",
    "deploy": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --env=\"\"",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:canary": "vitest run --config vitest.canary.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@insecur/access": "workspace:*",
    "@insecur/auth": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/instance-bootstrap": "workspace:*",
    "@insecur/onboarding": "workspace:*",
    "@insecur/operations": "workspace:*",
    "@insecur/runtime-injection": "workspace:*",
    "@insecur/secret-store": "workspace:*",
    "@insecur/tenant-store": "workspace:*",
    "@insecur/worker-kit": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@insecur/runtime": "workspace:*",
    "eslint": "catalog:",
    "postgres": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
