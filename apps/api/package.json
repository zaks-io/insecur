{
  "name": "@insecur/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run --outdir dist --env=\"\"",
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs wrangler dev --port 8787 --inspector-port 9230",
    "deploy": "WRANGLER_LOG_PATH=.wrangler/logs node ../../scripts/deploy-route-preserving-worker.mjs wrangler.jsonc -- --env=\"\"",
    "deploy:preview": "wrangler deploy --env preview --keep-vars",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:canary": "vitest run --config vitest.canary.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@insecur/auth": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/secret-store-contracts": "workspace:*",
    "@insecur/tenant-store": "workspace:*",
    "@insecur/worker-kit": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@insecur/runtime": "workspace:*",
    "eslint": "catalog:",
    "postgres": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
