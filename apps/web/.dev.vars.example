# Local-only secrets for the Web BFF (`insecur-web`), loaded by `wrangler dev` / Vite.
# Copy to apps/web/.dev.vars and fill in. Never commit real secrets.
#
# The Web BFF holds NO keyring and NO database binding. It owns the browser session cookie and
# reaches the API Worker over the private API Service Binding with a scoped hop token (ADR-0051).
#
# Deployed/preview environments deliver these via encrypted Worker secrets, not plaintext vars.

WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
SESSION_SIGNING_SECRET=

# Cloudflare Turnstile. Dummy keys are safe for local development and automated tests.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Optional local Sentry error reporting. DSNs are public, but keep local files ignored.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_SERVICE=insecur-web
