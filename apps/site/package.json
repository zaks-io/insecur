{
  "name": "@insecur/site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs vite dev --port 8789",
    "deploy": "WRANGLER_LOG_PATH=.wrangler/logs node ../../scripts/deploy-route-preserving-worker.mjs dist/server/wrangler.json -- --outdir dist",
    "deploy:preview": "wrangler deploy --outdir dist --env preview --keep-vars",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler .output"
  },
  "dependencies": {
    "@insecur/ui": "workspace:*",
    "@sentry/cloudflare": "^10.63.0",
    "@sentry/tanstackstart-react": "^10.63.0",
    "@tanstack/react-router": "^1.168.26",
    "@tanstack/react-start": "^1.168.26",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.38.0",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "catalog:",
    "tailwindcss": "^4.3.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
