{
  "name": "@insecur/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "topo": "node -e \"\"",
    "build": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run --outdir dist",
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs wrangler dev",
    "deploy": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@insecur/access": "workspace:*",
    "@insecur/audit": "workspace:*",
    "@insecur/auth": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/onboarding": "workspace:*",
    "@insecur/runtime-injection": "workspace:*",
    "@insecur/secrets": "workspace:*",
    "@insecur/tenant-store": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
