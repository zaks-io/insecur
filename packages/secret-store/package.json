{
  "name": "@insecur/secret-store",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.config.ts",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@insecur/access": "workspace:*",
    "@insecur/audit": "workspace:*",
    "@insecur/crypto": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/secret-store-contracts": "workspace:*",
    "@insecur/tenant-store": "workspace:*"
  },
  "devDependencies": {
    "@insecur/tenant-keyring": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
