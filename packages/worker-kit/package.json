{
  "name": "@insecur/worker-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./rpc/runtime-connections-rpc-contract": "./src/rpc/runtime-connections-rpc-contract.ts",
    "./rpc/runtime-run-policies-rpc-contract": "./src/rpc/runtime-run-policies-rpc-contract.ts"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@insecur/access": "workspace:*",
    "@insecur/audit": "workspace:*",
    "@insecur/auth": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/instance-bootstrap": "workspace:*",
    "@insecur/onboarding": "workspace:*",
    "@insecur/operations": "workspace:*",
    "@insecur/runtime-injection-issue": "workspace:*",
    "@insecur/secret-store-contracts": "workspace:*",
    "@insecur/tenant-store": "workspace:*",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
