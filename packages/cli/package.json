{
  "name": "@insecur/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "insecur": "./dist/index.js"
  },
  "scripts": {
    "topo": "node -e \"\"",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "start": "node --import tsx/esm src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@insecur/auth": "workspace:*",
    "@insecur/domain": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
