{
  "name": "@insecur/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "insecur": "./dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "start": "node --import tsx/esm src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@insecur/agent-attribution": "workspace:*",
    "@insecur/audit": "workspace:*",
    "@insecur/auth": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/local-store": "workspace:*",
    "@insecur/worker-kit": "workspace:*",
    "@types/node": "catalog:",
    "commander": "^15.0.0",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
