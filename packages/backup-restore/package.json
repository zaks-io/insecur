{
  "name": "@insecur/backup-restore",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "fixture-self-test": "tsx src/cli.ts fixture-self-test",
    "verify-evidence": "tsx src/cli.ts verify-evidence",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.config.ts",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@insecur/audit": "workspace:*",
    "@insecur/crypto": "workspace:*",
    "@insecur/domain": "workspace:*",
    "@insecur/operations": "workspace:*",
    "@insecur/tenant-store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "postgres": "catalog:"
  }
}
