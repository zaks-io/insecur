{
  "name": "@insecur/preview-smoke",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "smoke:preview": "playwright test -c playwright.preview.config.ts --fail-on-flaky-tests",
    "sweep:artifacts": "node --import tsx/esm src/artifact-sweep-cli.ts",
    "sweep:r2-backup": "node --import tsx/esm src/r2-backup-sweep-cli.ts",
    "test": "vitest run",
    "lint": "eslint \"playwright.preview.config.ts\" \"src/**/*.ts\" \"tests/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf ../../preview-smoke-artifacts"
  },
  "dependencies": {
    "@insecur/audit": "workspace:*",
    "@insecur/auth": "workspace:*",
    "@insecur/backup-restore": "workspace:*",
    "@insecur/domain": "workspace:*",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@insecur/release-gate": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
