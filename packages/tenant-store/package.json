{
  "name": "@insecur/tenant-store",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run --config vitest.config.ts",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "migrate:local": "node ./scripts/migrate.mjs",
    "assert:rls-credentials": "node ./scripts/assert-rls-credentials.mjs",
    "assert:ci-rls-gate-env": "node ./scripts/assert-ci-rls-gate-env.mjs",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "schema-shape:generate": "node --import tsx/esm scripts/generate-schema-shape-registry.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@insecur/custody-contracts": "workspace:*",
    "@insecur/domain": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@insecur/crypto": "workspace:*",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
