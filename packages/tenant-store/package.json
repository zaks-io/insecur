{
  "name": "@insecur/tenant-store",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "topo": "node -e \"\"",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "migrate:local": "node ./scripts/migrate.mjs",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@insecur/crypto": "workspace:*",
    "@insecur/domain": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
