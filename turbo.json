{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "strict",
  "globalDependencies": [
    ".env",
    ".env.*",
    ".node-version",
    ".nvmrc",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.base.json",
    "eslint.config.ts",
    ".prettierrc.json",
    ".prettierignore"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "futureFlags": {
    "longerSignatureKey": true
  },
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["CLOUDFLARE_ENV"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["topo", "^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["topo", "^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["topo", "^build"],
      "outputs": []
    },
    "@insecur/crypto#test": {
      "dependsOn": ["topo", "^build", "@insecur/runtime-injection#build"],
      "outputs": []
    },
    "test:rls": {
      "dependsOn": ["topo", "^build", "build"],
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_CI_RLS_GATE",
        "INSECUR_TEST_SKIP_MIGRATE"
      ]
    },
    "test:integration": {
      "dependsOn": ["topo", "^build"],
      "cache": false,
      "env": ["DATABASE_URL", "DATABASE_URL_MIGRATION", "DATABASE_URL_RUNTIME"]
    },
    "test:e2e": {
      "dependsOn": ["topo", "^build"],
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_CI_RLS_GATE",
        "INSECUR_TEST_SKIP_MIGRATE"
      ]
    },
    "test:canary": {
      "dependsOn": ["topo", "^build"],
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_CI_RLS_GATE",
        "INSECUR_TEST_SKIP_MIGRATE"
      ]
    },
    "typegen": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "env": ["CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_DB"],
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "assert:ci-rls-gate-env": {
      "cache": false,
      "env": ["INSECUR_CI_RLS_GATE"]
    },
    "migrate:local": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_POSTGRES_RUNTIME_ROLE"
      ]
    },
    "migrate:remote": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
