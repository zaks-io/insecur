{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "strict",
  "globalDependencies": [
    ".env",
    ".env.*",
    ".node-version",
    ".nvmrc",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.base.json",
    "eslint.config.ts",
    ".prettierrc.json",
    ".prettierignore"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "futureFlags": {
    "longerSignatureKey": true
  },
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "CLOUDFLARE_ENV",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOY_SHA",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/vitest.coverage.config.ts"],
      "outputs": ["coverage/**"]
    },
    "test:rls": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_CI_RLS_GATE",
        "INSECUR_TEST_SKIP_MIGRATE"
      ]
    },
    "test:integration": {
      "cache": false,
      "env": ["DATABASE_URL", "DATABASE_URL_MIGRATION", "DATABASE_URL_RUNTIME"]
    },
    "test:e2e": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_CI_RLS_GATE",
        "INSECUR_TEST_SKIP_MIGRATE"
      ]
    },
    "test:canary": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_CI_RLS_GATE",
        "INSECUR_TEST_SKIP_MIGRATE"
      ]
    },
    "@insecur/web#test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "typegen": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "env": ["CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_DB"],
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "INSECUR_REQUIRE_SENTRY_SOURCEMAPS",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ]
    },
    "@insecur/api#deploy": {
      "dependsOn": ["build", "@insecur/runtime#deploy"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "INSECUR_REQUIRE_SENTRY_SOURCEMAPS",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ]
    },
    "@insecur/web#deploy": {
      "dependsOn": ["build", "@insecur/api#deploy", "@insecur/runtime#deploy"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "INSECUR_REQUIRE_SENTRY_SOURCEMAPS",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ]
    },
    "deploy:preview": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "INSECUR_RUNTIME_SECRETS_FILE",
        "INSECUR_API_SECRETS_FILE",
        "INSECUR_WEB_SECRETS_FILE",
        "INSECUR_REQUIRE_SENTRY_SOURCEMAPS",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ]
    },
    "deploy:preview:dry-run": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "SENTRY_RELEASE"
      ]
    },
    "@insecur/api#deploy:preview": {
      "dependsOn": ["build", "@insecur/runtime#deploy:preview"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "INSECUR_RUNTIME_SECRETS_FILE",
        "INSECUR_API_SECRETS_FILE",
        "INSECUR_WEB_SECRETS_FILE",
        "INSECUR_REQUIRE_SENTRY_SOURCEMAPS",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ]
    },
    "@insecur/web#deploy:preview": {
      "dependsOn": ["build", "@insecur/api#deploy:preview", "@insecur/runtime#deploy:preview"],
      "cache": false,
      "env": ["CLOUDFLARE_ENV"],
      "passThroughEnv": [
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN",
        "INSECUR_DEPLOY_SHA",
        "INSECUR_DEPLOY_RUN_ID",
        "INSECUR_DEPLOYED_AT",
        "INSECUR_REQUIRE_DEPLOY_IDENTITY",
        "INSECUR_INSTANCE_ID",
        "INSECUR_SITE_AUDIT_EXPORT_SIGNING_PUBLIC_KEY",
        "INSECUR_TURNSTILE_SITE_KEY",
        "INSECUR_WORKOS_AUTHKIT_ORIGIN",
        "INSECUR_WORKOS_CLIENT_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_ONBOARDING_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_IP_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_BOOTSTRAP_ACTOR_NAMESPACE_ID",
        "INSECUR_API_RATELIMIT_AUTH_EXCHANGE_IP_NAMESPACE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_STORE_ID",
        "INSECUR_RUNTIME_ROOT_KEY_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_HMAC_SECRET_NAME",
        "INSECUR_RUNTIME_AUDIT_EXPORT_SIGNING_SECRET_NAME",
        "INSECUR_RUNTIME_BACKUPS_BUCKET_NAME",
        "INSECUR_RUNTIME_HYPERDRIVE_ID",
        "INSECUR_RUNTIME_SECRETS_FILE",
        "INSECUR_API_SECRETS_FILE",
        "INSECUR_WEB_SECRETS_FILE",
        "INSECUR_REQUIRE_SENTRY_SOURCEMAPS",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_RELEASE"
      ]
    },
    "assert:ci-rls-gate-env": {
      "cache": false,
      "env": ["INSECUR_CI_RLS_GATE"]
    },
    "migrate:local": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_MIGRATION",
        "DATABASE_URL_RUNTIME",
        "INSECUR_POSTGRES_RUNTIME_ROLE"
      ]
    },
    "migrate:remote": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
