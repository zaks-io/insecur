{
  "name": "insecur",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted secrets manager on Cloudflare Workers",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build --cache=local:rw,remote:r",
    "typecheck": "turbo run typecheck --cache=local:rw,remote:r",
    "lint": "turbo run lint --cache=local:rw,remote:r",
    "test": "turbo run test --cache=local:rw,remote:r",
    "test:rls": "turbo run test:rls",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm format:check && turbo run lint typecheck test --cache=local:rw,remote:r",
    "verify:ci": "pnpm format:check && turbo run lint typecheck test --cache=local:rw,remote:rw",
    "prepare": "node scripts/lefthook-install.mjs",
    "dev:check": "node scripts/dev-check.mjs",
    "dev:db:env": "node scripts/dev-db.mjs env",
    "dev:db:up": "node scripts/dev-db.mjs up",
    "dev:db:down": "node scripts/dev-db.mjs down",
    "dev:db:reset": "node scripts/dev-db.mjs reset",
    "dev:db:guard": "node scripts/dev-db.mjs guard",
    "doctor": "pnpm dev:check",
    "dev": "turbo run dev --cache=local:rw,remote:r",
    "dev:worker": "turbo run dev --filter @insecur/worker",
    "deploy:worker": "turbo run deploy --filter @insecur/worker",
    "cli": "pnpm --filter @insecur/cli start",
    "clean": "turbo run clean"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
